DISPLAY_NAME=My Environment

# AWS Region where GovOpenCodeAWS stacks are deployed
OPENCODE_AWS_REGION=us-east-1

# Telemetry/OTEL Configuration
OPENCODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_ENDPOINT=http://<otel-collector-alb>.elb.amazonaws.com
AUDIT_TABLE_NAME=AuditEvents

# Telemetry Control
OPENCODE_ENABLE_AUDIT=1
OPENCODE_METRICS_BATCH_SIZE=100
OPENCODE_METRICS_INTERVAL_SECONDS=10

# Endpoint for Quota and Models (admin-api stack output: AdminApiEndpoint)
OPENCODE_API_ENDPOINT=https://<api-id>.execute-api.<region>.amazonaws.com

# Quota Control (uses OPENCODE_API_ENDPOINT/quota)
QUOTA_FAIL_MODE=closed
OPENCODE_QUOTA_CHECK_INTERVAL=10

# Identity & Authentication
# Cognito values from bedrock-auth-cognito stack outputs
PROVIDER_DOMAIN=<pool-prefix>.auth.<region>.amazoncognito.com
CLIENT_ID=<cognito-app-client-id>
PROVIDER_TYPE=cognito
COGNITO_USER_POOL_ID=<region>_<pool-id>
IDENTITY_POOL_ID=<region>:<identity-pool-uuid>
FEDERATION_TYPE=cognito
# Credential storage and AWS region/profile configuration
# CREDENTIAL_STORAGE: "session" for commercial, "keyring" for GovCloud
CREDENTIAL_STORAGE=session
AWS_REGION_PROFILE=us-east-1
# CROSS_REGION_PROFILE: "us" for commercial, "us-gov" for GovCloud
CROSS_REGION_PROFILE=us
