{
  "$schema": "https://opencode.ai/config.json",
  "model": "zen/claude-opus-4-5",
  "default_agent": "devops_orchestrator",
  "keybinds": {
    "f9": "agent:prev",
    "f10": "agent:next"
  },
  "agent": {
    "devops_orchestrator": {
      "description": "DevOps Team Orchestrator - IaC, CI/CD pipelines, cloud deployments",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/agent/devops_orchestrator.md}"
    },
    "researcher": {
      "description": "Researcher + Planner - deep analysis, actionable plans",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/researcher.md}"
    },
    "implementor_devops": {
      "description": "Implementor DevOps - Terraform HCL, Dockerfiles, GitHub Actions YAML",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/implementor_devops.md}"
    },
    "tester_devops": {
      "description": "Tester DevOps - terraform plan, tfsec, checkov, YAML lint",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/tester_devops.md}"
    },
    "devops_expert": {
      "description": "DevOps Expert - infinity loop, CI/CD strategy, observability, SLOs",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/devops-expert.md}"
    },
    "terraform": {
      "description": "Terraform Specialist - HCP Terraform automation via MCP server",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/terraform.md}"
    },
    "terraform_reviewer": {
      "description": "Terraform IaC Reviewer - state safety, blast radius, least-privilege IAM",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/terraform-iac-reviewer.md}"
    },
    "documentation": {
      "description": "Documentation - maintains runbooks, architecture diagrams, and ADRs",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/documentation.md}"
    },
    "truth_teller": {
      "description": "Truth-Teller (default) - challenges assumptions",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_opus": {
      "description": "Truth-Teller (Opus) - Truth-teller using Claude Opus",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_qwen": {
      "description": "Truth-Teller (Qwen) - Truth-teller using Qwen3 Coder",
      "mode": "subagent",
      "model": "zen/qwen3-coder-480b",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_grok": {
      "description": "Truth-Teller (Grok) - Truth-teller using Grok",
      "mode": "subagent",
      "model": "zen/grok-3",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  }
}
