{
  "$schema": "https://opencode.ai/config.json",
  "model": "zen/claude-opus-4-5",
  "default_agent": "cpp_orchestrator",
  "keybinds": {
    "f9": "agent:prev",
    "f10": "agent:next"
  },
  "agent": {
    "cpp_orchestrator": {
      "description": "C++ Team Orchestrator - coordinates, delegates, synthesizes",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/agent/cpp_orchestrator.md}"
    },
    "researcher": {
      "description": "Researcher + Planner - deep analysis, actionable plans",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/researcher.md}"
    },
    "implementor_cpp": {
      "description": "Implementor C++ - modern C++ implementation with performance and safety focus",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/implementor_cpp.md}"
    },
    "documentation": {
      "description": "Documentation - maintains PlantUML diagrams, ADRs, and technical docs",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/documentation.md}"
    },
    "tester_cpp": {
      "description": "Tester C++ - validates behavior with tests, sanitizers, and coverage",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/tester_cpp.md}"
    },
    "truth_teller": {
      "description": "Truth-Teller (default) - challenges assumptions",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_opus": {
      "description": "Truth-Teller (Opus) - Truth-teller using Claude Opus",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_qwen": {
      "description": "Truth-Teller (Qwen) - Truth-teller using Qwen3 Coder",
      "mode": "subagent",
      "model": "zen/qwen3-coder-480b",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_grok": {
      "description": "Truth-Teller (Grok) - Truth-teller using Grok",
      "mode": "subagent",
      "model": "zen/grok-3",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  }
}
