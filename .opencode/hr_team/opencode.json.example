{
  "$schema": "https://opencode.ai/config.json",
  "model": "zen/claude-opus-4-5",
  "default_agent": "hr_orchestrator",
  "keybinds": {
    "f9": "agent:prev",
    "f10": "agent:next"
  },
  "agent": {
    "hr_orchestrator": {
      "description": "HR Team Orchestrator - AI governance, compliance, triage, localization",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/agent/hr_orchestrator.md}"
    },
    "researcher": {
      "description": "Researcher + Planner - deep analysis, actionable plans",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/researcher.md}"
    },
    "implementor_hr": {
      "description": "Implementor HR - governance policies, audit logging, safety controls",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/implementor_hr.md}"
    },
    "reviewer_hr": {
      "description": "Reviewer HR - validates governance completeness and AI safety controls",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/reviewer_hr.md}"
    },
    "governance_reviewer": {
      "description": "Governance Reviewer - reviews code for missing safety and governance controls",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/governance-reviewer.md}"
    },
    "translator": {
      "description": "Translator - translates content while preserving technical terms",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/translator.md}"
    },
    "triage": {
      "description": "Triage Agent - GitHub issue triage, labels and owner assignment",
      "prompt": "{file:~/.config/opencode/agent/triage.md}"
    },
    "duplicate_pr": {
      "description": "Duplicate PR Detector - searches for duplicate open PRs",
      "prompt": "{file:~/.config/opencode/agent/duplicate-pr.md}"
    },
    "documentation": {
      "description": "Documentation - maintains ADRs, governance docs, and API docs",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/documentation.md}"
    },
    "truth_teller": {
      "description": "Truth-Teller (default) - challenges assumptions",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_opus": {
      "description": "Truth-Teller (Opus) - Truth-teller using Claude Opus",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_qwen": {
      "description": "Truth-Teller (Qwen) - Truth-teller using Qwen3 Coder",
      "mode": "subagent",
      "model": "zen/qwen3-coder-480b",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_grok": {
      "description": "Truth-Teller (Grok) - Truth-teller using Grok",
      "mode": "subagent",
      "model": "zen/grok-3",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  }
}
