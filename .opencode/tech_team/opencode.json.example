{
  "$schema": "https://opencode.ai/config.json",
  "model": "zen/claude-opus-4-5",
  "default_agent": "tech_orchestrator",
  "keybinds": {
    "f9": "agent:prev",
    "f10": "agent:next"
  },
  "agent": {
    "tech_orchestrator": {
      "description": "Tech Team Orchestrator - general software engineering across any stack",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/agent/tech_orchestrator.md}"
    },
    "researcher": {
      "description": "Researcher + Planner - deep analysis, actionable plans",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/researcher.md}"
    },
    "implementor_tech": {
      "description": "Implementor Tech - feature work, refactors, bug fixes across any language",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/implementor_tech.md}"
    },
    "tester_tech": {
      "description": "Tester Tech - test design, execution, coverage validation",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/tester_tech.md}"
    },
    "principal_engineer": {
      "description": "Principal Engineer - architecture, GoF patterns, SOLID, technical debt",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/principal-software-engineer.md}"
    },
    "software_engineer": {
      "description": "Software Engineer - autonomous executor with zero-confirmation policy",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/software-engineer-agent.md}"
    },
    "documentation": {
      "description": "Documentation - maintains architecture docs, ADRs, and API docs",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/agent/documentation.md}"
    },
    "truth_teller": {
      "description": "Truth-Teller (default) - challenges assumptions",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_opus": {
      "description": "Truth-Teller (Opus) - Truth-teller using Claude Opus",
      "mode": "subagent",
      "model": "zen/claude-opus-4-5",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_qwen": {
      "description": "Truth-Teller (Qwen) - Truth-teller using Qwen3 Coder",
      "mode": "subagent",
      "model": "zen/qwen3-coder-480b",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "truth_teller_grok": {
      "description": "Truth-Teller (Grok) - Truth-teller using Grok",
      "mode": "subagent",
      "model": "zen/grok-3",
      "prompt": "{file:~/.config/opencode/agent/truth_teller.md}"
    },
    "plan": { "disable": true },
    "build": { "disable": true }
  }
}
