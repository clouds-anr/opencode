# OpenCode ANR — CCWB Commercial Account (357229908994, us-east-2)
# Connects to Avonte's GovOpenCodeAWS stacks deployed in commercial AWS
# Profile: claudecodebedrock

OPENCODE_AWS_PROFILE=claudecodebedrock
OPENCODE_AWS_REGION=us-east-2

# Telemetry/OTEL Configuration
OPENCODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-alb-1016193982.us-east-2.elb.amazonaws.com
AUDIT_TABLE_NAME=AuditEvents

# Telemetry Control
OPENCODE_ENABLE_AUDIT=1
OPENCODE_METRICS_BATCH_SIZE=100
OPENCODE_METRICS_INTERVAL_SECONDS=10

# Endpoint for Quota and Models
OPENCODE_API_ENDPOINT=https://a80ywisnia.execute-api.us-east-2.amazonaws.com

# Quota Control (uses OPENCODE_API_ENDPOINT/quota)
QUOTA_FAIL_MODE=closed
OPENCODE_QUOTA_CHECK_INTERVAL=10

# Identity & Authentication
# Cognito provider configuration for OIDC authentication
PROVIDER_DOMAIN=us-east-2m3mllrjsa.auth.us-east-2.amazoncognito.com
CLIENT_ID=687l9t5094usr3e822u01ihho3
PROVIDER_TYPE=cognito
COGNITO_USER_POOL_ID=us-east-2_M3mLLrjsa
IDENTITY_POOL_ID=us-east-2:ceaecfb3-4117-4436-8e21-b998ebaeee7c
FEDERATION_TYPE=cognito
# Credential storage and AWS region/profile configuration
CREDENTIAL_STORAGE=session
AWS_REGION_PROFILE=us-east-2
CROSS_REGION_PROFILE=us
