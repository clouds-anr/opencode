{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.0.0",
  "name": "@opencode-ai/opencode-anr",
  "type": "module",
  "license": "PROPRIETARY",
  "private": true,
  "description": "Alaska Northstar Resources custom OpenCode distribution with enterprise integrations",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 30000",
    "build": "bun run script/build.ts",
    "dev": "bun run src/index.ts",
    "cli": "bun run bin/opencode-anr"
  },
  "bin": {
    "opencode-anr": "./bin/opencode-anr"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "opencode": "workspace:*",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-cognito-identity": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.54.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
