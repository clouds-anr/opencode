DISPLAY_NAME=CCWB GovCloud (us-gov-west-1)

# OpenCode ANR — GovEikon GovCloud Account (610113251594, us-gov-west-1)
# Connects to GovOpenCodeAWS stacks deployed in AWS GovCloud
# Profile: TBD (set after GovCloud SSO is configured)

OPENCODE_AWS_PROFILE=<FILL_AFTER_SSO_SETUP>
OPENCODE_AWS_REGION=us-gov-west-1

# Telemetry/OTEL Configuration
OPENCODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/json
OTEL_EXPORTER_OTLP_ENDPOINT=<FILL_AFTER_DEPLOY>
AUDIT_TABLE_NAME=AuditEvents

# Telemetry Control
OPENCODE_ENABLE_AUDIT=1
OPENCODE_METRICS_BATCH_SIZE=100
OPENCODE_METRICS_INTERVAL_SECONDS=10

# Endpoint for Quota and Models
OPENCODE_API_ENDPOINT=<FILL_AFTER_DEPLOY>

# Quota Control (uses OPENCODE_API_ENDPOINT/quota)
QUOTA_FAIL_MODE=closed
OPENCODE_QUOTA_CHECK_INTERVAL=10

# Identity & Authentication
# Cognito provider configuration for OIDC authentication (FIPS endpoint for GovCloud)
PROVIDER_DOMAIN=<FILL_AFTER_DEPLOY>
CLIENT_ID=<FILL_AFTER_DEPLOY>
PROVIDER_TYPE=cognito
COGNITO_USER_POOL_ID=<FILL_AFTER_DEPLOY>
IDENTITY_POOL_ID=<FILL_AFTER_DEPLOY>
FEDERATION_TYPE=cognito
# Credential storage and AWS region/profile configuration
CREDENTIAL_STORAGE=session
AWS_REGION_PROFILE=us-gov-west-1
CROSS_REGION_PROFILE=us-gov
