# Bedrock environment configuration
AWS_PROFILE=anr-bedrock-internal-us-east-1
AWS_REGION=us-east-2

# Telemetry/OTEL Configuration
OPENCODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector-alb-395007917.us-east-2.elb.amazonaws.com
AUDIT_TABLE_NAME=AuditEvents

# Telemetry Control
# OPENCODE_ENABLE_AUDIT: Enable/disable audit logging to DynamoDB (default: 1/true)
OPENCODE_ENABLE_AUDIT=1
# OPENCODE_METRICS_BATCH_SIZE: Number of metrics to batch before exporting (default: 100)
OPENCODE_METRICS_BATCH_SIZE=100
# OPENCODE_METRICS_INTERVAL_SECONDS: Interval for periodic metric exports in seconds (default: 60)
OPENCODE_METRICS_INTERVAL_SECONDS=10

# Quota Control
QUOTA_API_ENDPOINT=https://qzv3ldfxl2.execute-api.us-east-2.amazonaws.com
QUOTA_FAIL_MODE=closed
# OPENCODE_QUOTA_CHECK_INTERVAL: Check frequency - "PROMPT" for per-prompt checks, or seconds (default: 300 for 5min)
OPENCODE_QUOTA_CHECK_INTERVAL=300

# Identity & Authentication
# Cognito provider configuration for OIDC authentication
PROVIDER_DOMAIN=us-east-2aytgxogxn.auth.us-east-2.amazoncognito.com
CLIENT_ID=7o9q9dki6basqd9a34grjd9oma
PROVIDER_TYPE=cognito
COGNITO_USER_POOL_ID=us-east-2_aytGXogxn
IDENTITY_POOL_ID=us-east-2:122b8cce-bcee-4ecb-b513-b1d28fa7072d
FEDERATION_TYPE=cognito
# Credential storage and AWS region/profile configuration
CREDENTIAL_STORAGE=session
AWS_REGION_PROFILE=us-east-2
CROSS_REGION_PROFILE=us

# Installer download URLs (optional — override for internal mirrors or air-gapped environments)
# INSTALLER_URL_CLAUDE=https://claude.ai/install.sh
# INSTALLER_URL_GIT=https://github.com/git-for-windows/git/releases/latest/download/Git-2.47.1-64-bit.exe
