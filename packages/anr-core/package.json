{
  "$schema": "https://json.schemastore.org/package.json",
  "version": "1.0.0",
  "name": "@opencode-ai/anr-core",
  "type": "module",
  "license": "PROPRIETARY",
  "private": true,
  "description": "Shared ANR (Alaska Northstar Resources) core functionality for authentication, telemetry, quota management, and database connections",
  "exports": {
    ".": "./src/index.ts",
    "./util/debug-logger": "./src/util/debug-logger.ts",
    "./util/metrics-validator": "./src/util/metrics-validator.ts",
    "./util/context-tracer": "./src/util/context-tracer.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test:otel": "bun run --env-file=../../.env.bedrock src/util/otel-e2e-test.ts",
    "verify:cw": "bun run src/util/otel-verify-cloudwatch.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity": "^3.700.0",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-sts": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "1.27.0",
    "@opentelemetry/otlp-transformer": "0.54.0",
    "@opentelemetry/resources": "1.27.0",
    "@opentelemetry/sdk-metrics": "1.27.0",
    "@opentelemetry/sdk-node": "0.54.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
