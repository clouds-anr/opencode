{
  "folders": [
    {
      "path": ".",
      "name": "ANR Enterprise"
    }
  ],
  "settings": {
    "extensions.ignoreRecommendations": false,
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "[json]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode",
      "editor.formatOnSave": true
    },
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    },
    "search.exclude": {
      "**/node_modules": true,
      "**/.turbo": true,
      "**/dist": true,
      "**/build": true
    },
    "files.exclude": {
      "**/node_modules": true,
      "**/.turbo": true
    }
  },
  "extensions": {
    "recommendations": [
      "esbenp.prettier-vscode",
      "dbaeumer.vscode-eslint",
      "github.copilot",
      "github.copilot-chat"
    ]
  }
}
